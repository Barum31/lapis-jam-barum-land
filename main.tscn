[node name="UÜSK Eğitim Binası" type="StaticBody3D" parent="Map/hazırlık" index="0" unique_id=142895308]
script = ExtResource("3_h2yge")
bina_ozel_ismi = "UÜSK Eğitim Binası"
bina_detay_bilgisi = " UÜSK Akademisyeni Doç.Dr. Regaip Kuru:
 Doç. Dr. Regaip Kuru  erken yaşlılık döneminde, hafif kilolu, kel ve gözlüklü bir akademisyendir. Yeni yönetime alışmaya çalışan, nasırına basılmış adam gibi huysuz  ve demokrasi kadar eskide kalmış bir adamdır. Devrimden önce eğitim verdiği kurumda ‘ Terör ve kaosa yol açabilecek bilgiler yayma’ suçlamasıyla UÜSK kampına yollanmıştır. Buraya geldikten sonra Kasım Lam’ın meşhur  ‘Yeniden Eğitim’ programıyla tanışmış ve bu eğitim sonucunda sol kolunu kaybetmiştir. O günden beri sadece USAK tarafından verilen bilgileri okumak ve öğretmek ile ilgilenmiş, yeni bir çalışmada bulunmamıştır.
"

