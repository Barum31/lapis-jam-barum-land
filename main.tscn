[node name="UÜSK Yemekhane Binası" type="StaticBody3D" parent="Map/sks" parent_id_path=PackedInt32Array(953951384, 1863052537) index="0" unique_id=706274284]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.0056079626, 0.01427722, 0.03142614)
script = ExtResource("3_h2yge")
bina_ozel_ismi = "UÜSK Yemekhane Binası"
bina_detay_bilgisi = "UÜSK Aşçıbaşı Gülizar Tayf:
   Gülizar Tayf orta yaşlı, oldukça zayıf, her haliyle çelimsiz bir aşçıbaşıdır. Kedi kadar ürkek, manik depresif ve altındaki aşçıların onu zehirlemeye çalıştığını düşünecek kadar paranoyak bir yapıya sahip olan Gülizar Tayf’ın bu hale gelmesinin tek sebebi Kasım Lam’dır.  Kasım Lam, Gülizar Tayf’ın eşini ve çocuklarını yemekhaneden erzak çalmak ile suçlamış; daha sonrasında onları Gülizar Tayf’ın gözleri önünde demir bir sopa ile döverek acımasızca katletmiştir. Kasım Lam, bununla kalmamış ve Gülizar Tayf’ı ‘yeniden eğitim’ programına sokmuştur. Bu ‘eğitimin’ sonucunda Gülizar Tayf, bugün bildiğimiz korkak, paranoyak, manik depresif  ve son derece çelimsiz olan zayıf insana dönüşmüştür.
"

